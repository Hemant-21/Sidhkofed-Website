  descriptionEn        String?          @map("description_en")
  descriptionHi        String?          @map("description_hi")
  objectivesEn         String?          @map("objectives_en")
  objectivesHi         String?          @map("objectives_hi")
  eligibilityEn        String?          @map("eligibility_en")
  eligibilityHi        String?          @map("eligibility_hi")
  benefitsEn           String?          @map("benefits_en")
  benefitsHi           String?          @map("benefits_hi")
  applicationProcessEn String?          @map("application_process_en")
  applicationProcessHi String?          @map("application_process_hi")
  fundingSource        String?          @map("funding_source")
  startDate            DateTime?        @map("start_date") @db.Date
