# ─────────────────────────────────────────────────────────────────────────────
# SIDHKOFED CMS — Backend environment template (Phase 1)
# Copy to `.env` and fill real values. NEVER commit `.env` (it is in .gitignore).
# All variables are validated at boot by src/config; the app fails fast if a
# required variable is missing or malformed.
#
# SECRETS POLICY & ROTATION
#   • This file is a TEMPLATE. It must contain only placeholders (CHANGE_ME / <...>),
#     never live credentials, project refs, hostnames or passwords.
#   • Generate strong secrets: `openssl rand -base64 48` for JWT_SECRET / IP_HASH_SALT
#     (>= 32 random chars). Use a unique, strong DB and Super Admin password.
#   • Rotate on a schedule and immediately on suspected exposure:
#       - JWT_SECRET: rotate quarterly (invalidates existing access/refresh tokens).
#       - IP_HASH_SALT: rotate yearly (changes enquiry IP-hash fingerprints).
#       - DATABASE_URL / S3_* / SMTP_PASSWORD / CAPTCHA_SECRET: rotate per provider
#         policy and after any leak; update the deployment secret store, then redeploy.
#       - SEED_SUPERADMIN_PASSWORD: change the admin password after first login.
#   • Store real secrets in the deployment secret manager, not in the repo.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development                     # development | test | production
APP_NAME=sidhkofed-cms
APP_PORT=4000
API_BASE_PATH=/api/v1                    # immutable v1 contract
PUBLIC_WEBSITE_URL=http://localhost:3000 # used for absolute links / CORS / SEO
LOG_LEVEL=info                           # debug | info | warn | error

# ── Database (PostgreSQL + Prisma) ───────────────────────────────────────────
# DATABASE_URL=postgresql://sidhkofed:CHANGE_ME@localhost:5432/sidhkofed_cms?schema=public
# Optional read replica for public read traffic (falls back to DATABASE_URL):
# Example: managed Postgres via a transaction-mode pooler (IPv4-only). Replace the
# project ref, region, user and password with your own — never commit real values.
# DATABASE_URL="postgresql://<db-user>.<project-ref>:CHANGE_ME@<pooler-host>:6543/postgres?pgbouncer=true"

# # Example: session-mode pooler (used for migrations):
# DIRECT_URL="postgresql://<db-user>.<project-ref>:CHANGE_ME@<pooler-host>:5432/postgres"

DATABASE_REPLICA_URL=
DB_POOL_MAX=10                           # tune with PgBouncer in production

# ── Redis (cache / sessions / job queue) ─────────────────────────────────────
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=300                    # public GET / master-list cache TTL
QUEUE_PREFIX=sidhkofed                   # BullMQ namespace

# ── Auth / JWT ───────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_min_32_chars_random_secret
JWT_ACCESS_TTL=900                       # access token lifetime (seconds, short-lived)
JWT_REFRESH_TTL=2592000                  # refresh token lifetime (seconds, 30d)
JWT_ISSUER=sidhkofed-cms
REFRESH_COOKIE_NAME=sidhkofed_rt
REFRESH_COOKIE_SECURE=false              # true in production (HTTPS only)
REFRESH_COOKIE_SAMESITE=lax              # lax | strict | none
PASSWORD_HASH_ROUNDS=12                  # bcrypt/argon work factor

# ── Seed: default Super Admin (read ONLY by `npm run db:seed`, not by the API) ─
# Required when running the seeder. Use a strong password; rotate after first login.
SEED_SUPERADMIN_EMAIL=admin@sidhkofed.example
SEED_SUPERADMIN_PASSWORD=CHANGE_ME_strong_admin_password
SEED_SUPERADMIN_NAME=SIDHKOFED Super Admin

# ── Storage (media & documents) ──────────────────────────────────────────────
STORAGE_PROVIDER=local                   # local | s3   (private object storage)
STORAGE_LOCAL_ROOT=./storage             # used when STORAGE_PROVIDER=local
STORAGE_PUBLIC_BASE_URL=http://localhost:4000/files  # CDN/signed-URL delivery base
# S3-compatible (used when STORAGE_PROVIDER=s3):
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true
SIGNED_URL_TTL_SECONDS=600

# ── Upload limits / allowed types ────────────────────────────────────────────
UPLOAD_MAX_IMAGE_MB=10
UPLOAD_MAX_DOCUMENT_MB=25
UPLOAD_MAX_DATASET_MB=15                 # dashboard/membership XLSX/CSV
UPLOAD_BULK_MAX_FILES=50
UPLOAD_MAX_REQUEST_MB=60                  # aggregate cap for a whole multipart request (413 if exceeded)
UPLOAD_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/gif   # SVG disabled (security)
UPLOAD_ALLOWED_DOCUMENT_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document
UPLOAD_ALLOWED_DATASET_TYPES=text/csv,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet
MALWARE_SCAN_ENABLED=false               # true in production (quarantine before public)

# ── Email (single enquiry recipient + notifications) ─────────────────────────
EMAIL_ENABLED=false                      # mirrors Settings: enable/disable enquiry email
EMAIL_FROM="SIDHKOFED CMS <no-reply@sidhkofed.example>"
EMAIL_ENQUIRY_RECIPIENT=enquiries@sidhkofed.example  # single configurable recipient
EMAIL_SUBJECT_PREFIX=[SIDHKOFED Enquiry]
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=

# ── Abuse protection (enquiries) ─────────────────────────────────────────────
CAPTCHA_PROVIDER=none                    # none | recaptcha | turnstile
CAPTCHA_SECRET=
ENQUIRY_RATELIMIT_PER_IP_HOUR=5
ENQUIRY_RATELIMIT_PER_CONTACT_HOUR=3
IP_HASH_SALT=CHANGE_ME_random_salt       # salts source_ip_hash (privacy-safe)

# ── Rate limiting (Redis-backed; auth + uploads) ─────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN_MAX=5                    # login attempts per window
RATE_LIMIT_LOGIN_WINDOW_SEC=900          # 15 minutes
RATE_LIMIT_REFRESH_MAX=30                 # refresh requests per window
RATE_LIMIT_REFRESH_WINDOW_SEC=900
RATE_LIMIT_UPLOAD_MAX=60                  # media uploads per window
RATE_LIMIT_UPLOAD_WINDOW_SEC=900

# ── Localization ─────────────────────────────────────────────────────────────
DEFAULT_LANGUAGE=en                      # en | hi  (English primary)
SUPPORTED_LANGUAGES=en,hi
TRANSLATION_FALLBACK_ENABLED=false       # labeled machine-translation fallback (visitor-facing only)

# ── Background scheduler (Phase 14) ───────────────────────────────────────────
# Recurring maintenance jobs that reuse existing module services (no new APIs, no schema
# changes). Disable for an API-only process or in CI. Cron = standard 5-field expressions.
SCHEDULER_ENABLED=true                    # master switch (forced off under NODE_ENV=test)
SCHEDULER_TIMEZONE=Asia/Kolkata           # timezone used to evaluate the cron schedules
SCHEDULER_PUBLISHING_CRON=*/5 * * * *     # Job 1: publish records whose publish_start_at is due
SCHEDULER_HIGHLIGHT_CRON=*/5 * * * *      # Job 2: clear highlight_type after highlight_end_at passes
SCHEDULER_EVENT_STATUS_CRON=*/15 * * * *  # recompute date-derived event_status (scheduled→ongoing→completed)
SCHEDULER_DASHBOARD_REFRESH_CRON=0 * * * * # Job 4: refresh cached public dashboard/KPI aggregates
SCHEDULER_BATCH_SIZE=100                   # max records processed per job tick (bounds memory/queries)
SCHEDULER_JOB_ATTEMPTS=3                   # BullMQ retry attempts per failed tick
SCHEDULER_JOB_BACKOFF_MS=5000             # exponential backoff base between retries
SCHEDULER_LOCK_TTL_SECONDS=600            # Redis lock TTL guarding against overlapping runs
