# ─────────────────────────────────────────────────────────────────────────────
# SIDHKOFED CMS — Backend environment template (Phase 1)
# Copy to `.env` and fill real values. NEVER commit `.env`.
# All variables are validated at boot by src/config; the app fails fast if a
# required variable is missing or malformed.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development                     # development | test | production
APP_NAME=sidhkofed-cms
APP_PORT=4000
API_BASE_PATH=/api/v1                    # immutable v1 contract
PUBLIC_WEBSITE_URL=http://localhost:3000 # used for absolute links / CORS / SEO
LOG_LEVEL=info                           # debug | info | warn | error

# ── Database (PostgreSQL + Prisma) ───────────────────────────────────────────
DATABASE_URL=postgresql://sidhkofed:CHANGE_ME@localhost:5432/sidhkofed_cms?schema=public
# Optional read replica for public read traffic (falls back to DATABASE_URL):
DATABASE_REPLICA_URL=
DB_POOL_MAX=10                           # tune with PgBouncer in production

# ── Redis (cache / sessions / job queue) ─────────────────────────────────────
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=300                    # public GET / master-list cache TTL
QUEUE_PREFIX=sidhkofed                   # BullMQ namespace

# ── Auth / JWT ───────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_min_32_chars_random_secret
JWT_ACCESS_TTL=900                       # access token lifetime (seconds, short-lived)
JWT_REFRESH_TTL=2592000                  # refresh token lifetime (seconds, 30d)
JWT_ISSUER=sidhkofed-cms
REFRESH_COOKIE_NAME=sidhkofed_rt
REFRESH_COOKIE_SECURE=false              # true in production (HTTPS only)
REFRESH_COOKIE_SAMESITE=lax              # lax | strict | none
PASSWORD_HASH_ROUNDS=12                  # bcrypt/argon work factor

# ── Storage (media & documents) ──────────────────────────────────────────────
STORAGE_PROVIDER=local                   # local | s3 | gcs   (private object storage)
STORAGE_LOCAL_ROOT=./storage             # used when STORAGE_PROVIDER=local
STORAGE_PUBLIC_BASE_URL=http://localhost:4000/files  # CDN/signed-URL delivery base
# S3-compatible (used when STORAGE_PROVIDER=s3):
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true
SIGNED_URL_TTL_SECONDS=600

# ── Upload limits / allowed types ────────────────────────────────────────────
UPLOAD_MAX_IMAGE_MB=10
UPLOAD_MAX_DOCUMENT_MB=25
UPLOAD_MAX_DATASET_MB=15                 # dashboard/membership XLSX/CSV
UPLOAD_BULK_MAX_FILES=50
UPLOAD_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/svg+xml
UPLOAD_ALLOWED_DOCUMENT_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document
UPLOAD_ALLOWED_DATASET_TYPES=text/csv,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet
MALWARE_SCAN_ENABLED=false               # true in production (quarantine before public)

# ── Email (single enquiry recipient + notifications) ─────────────────────────
EMAIL_ENABLED=false                      # mirrors Settings: enable/disable enquiry email
EMAIL_FROM="SIDHKOFED CMS <no-reply@sidhkofed.example>"
EMAIL_ENQUIRY_RECIPIENT=enquiries@sidhkofed.example  # single configurable recipient
EMAIL_SUBJECT_PREFIX=[SIDHKOFED Enquiry]
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=

# ── Abuse protection (enquiries) ─────────────────────────────────────────────
CAPTCHA_PROVIDER=none                    # none | recaptcha | turnstile
CAPTCHA_SECRET=
ENQUIRY_RATELIMIT_PER_IP_HOUR=5
ENQUIRY_RATELIMIT_PER_CONTACT_HOUR=3
IP_HASH_SALT=CHANGE_ME_random_salt       # salts source_ip_hash (privacy-safe)

# ── Localization ─────────────────────────────────────────────────────────────
DEFAULT_LANGUAGE=en                      # en | hi  (English primary)
SUPPORTED_LANGUAGES=en,hi
TRANSLATION_FALLBACK_ENABLED=false       # labeled machine-translation fallback (visitor-facing only)
