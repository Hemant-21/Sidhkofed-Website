{
  "name": "sidhkofed-web",
  "version": "0.1.0",
  "private": true,
  "description": "SIDHKOFED public website (Phase 16). Next.js 14 App Router, SSR/ISR, consumes the public CMS APIs only. No admin features, no backend logic.",
